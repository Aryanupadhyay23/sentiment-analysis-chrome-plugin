{
  "manifest_version": 3,
  "name": "YouTube Sentiment Analyzer",
  "version": "2.0",
  "description": "Analyze YouTube comments using AI-powered sentiment analysis.",

  "action": {
    "default_popup": "popup.html"
  },

  "permissions": [
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.googleapis.com/*",
    "http://localhost:5000/*"
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  }
}