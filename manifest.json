{
  "manifest_version": 3,
  "name": "YouTube Sentiment Analysis",
  "version": "1.0",
  "description": "Fetch YouTube comments and run sentiment analysis.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": ["tabs"],
  "host_permissions": [
    "https://www.googleapis.com/*",
    "http://localhost:5000/*"
  ]
}